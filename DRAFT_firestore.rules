rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData(request.auth.uid).role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.keys().size() <= 7 && // uid, email, role, displayName, photoURL, createdAt, updatedAt
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['student', 'faculty', 'admin'] &&
             data.displayName is string && data.displayName.size() <= 100;
    }

    function isValidMaterial(data) {
      return data.keys().hasAll(['title', 'content', 'type', 'facultyId', 'status']) &&
             data.keys().size() <= 10 &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 100000 && // Large content allowed
             data.type in ['research_paper', 'subject_material', 'question_paper'] &&
             data.status in ['pending', 'validated'] &&
             data.facultyId == request.auth.uid;
    }

    function isValidMessage(data) {
      return data.role in ['user', 'assistant'] &&
             data.content is string && data.content.size() <= 10000 &&
             data.timestamp == request.time;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().role == existing().role; // Role is immutable for the user
      allow delete: if isAdmin();
    }

    match /materials/{materialId} {
      allow get: if isSignedIn(); // Any student can see individual material
      allow list: if isSignedIn() && (resource.data.status == 'validated' || resource.data.facultyId == request.auth.uid || isAdmin());
      allow create: if (hasRole('faculty') || hasRole('admin')) && isValidMaterial(incoming());
      allow update: if (isAdmin() || (hasRole('faculty') && existing().facultyId == request.auth.uid)) && 
                      isValidMaterial(incoming()) &&
                      incoming().facultyId == existing().facultyId; // cannot change owner
      allow delete: if isAdmin() || (hasRole('faculty') && existing().facultyId == request.auth.uid);
    }

    match /chats/{chatId} {
      allow get, create, update: if isSignedIn() && (incoming().userId == request.auth.uid || existing().userId == request.auth.uid);
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
        allow create: if isSignedIn() && 
                        get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid &&
                        isValidMessage(incoming());
      }
    }
  }
}
