rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isVerifiedFaculty() {
      return hasRole('faculty') || isAdmin();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['student', 'faculty', 'admin'];
    }

    function isValidMaterial(data) {
      return data.keys().hasAll(['title', 'content', 'type', 'facultyId', 'status']) &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 100000 &&
             data.type in ['research_paper', 'subject_material', 'question_paper'] &&
             data.status in ['pending', 'validated'] &&
             data.facultyId == request.auth.uid;
    }

    function isValidMessage(data) {
      return data.role in ['user', 'assistant'] &&
             data.content is string && data.content.size() <= 10000 &&
             data.timestamp == request.time;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().role == existing().role;
    }

    match /materials/{materialId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (
        resource.data.status == 'validated' || 
        resource.data.facultyId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isVerifiedFaculty() && isValidMaterial(incoming());
      allow update: if (isAdmin() || (isVerifiedFaculty() && existing().facultyId == request.auth.uid)) && 
                      isValidMaterial(incoming()) &&
                      incoming().facultyId == existing().facultyId;
      allow delete: if isAdmin() || (isVerifiedFaculty() && existing().facultyId == request.auth.uid);
    }

    match /chats/{chatId} {
      // Insecure check for list queries - corrected below
      allow read, write: if isSignedIn() && (
        (resource != null && resource.data.userId == request.auth.uid) ||
        (request.resource != null && request.resource.data.userId == request.auth.uid)
      );

      match /messages/{messageId} {
        allow read: if isSignedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
        allow create: if isSignedIn() && 
                        get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid &&
                        isValidMessage(incoming());
      }
    }

    // Admin collection for role verification
    match /admins/{adminId} {
      allow read: if isSignedIn();
    }
  }
}
